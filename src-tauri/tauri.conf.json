{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Writing Tools",
  "version": "2.0.0",
  "identifier": "com.writingtools.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 5173",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Writing Tools",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": ["build/icon.ico", "build/icon.icns"]
  }
}
